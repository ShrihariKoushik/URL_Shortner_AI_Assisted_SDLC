# Copy this file to .env and fill in your provider details.  .env is gitignored;
# this .env.example is the safe, committable template (no real secrets here).
#
# The engine calls any OpenAI-compatible Chat Completions endpoint, so you can use
# OpenAI, DeepSeek, a Meta Llama host (Together/Groq/Fireworks/OpenRouter), or
# Anthropic Claude via an OpenAI-compatible gateway. Uncomment ONE provider block.
#
# If a provider rejects the request (e.g. no JSON mode) or no key is set, the app
# automatically falls back to its deterministic, offline engine — it still runs.

# Master switch. Set to false to run fully offline (no API calls at all).
AI_SHORTENER_OPENAI_ENABLED=true

# ---------------------------------------------------------------------------
# OpenAI
AI_SHORTENER_OPENAI_PROVIDER=openai
AI_SHORTENER_OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
AI_SHORTENER_OPENAI_MODEL=gpt-4.1
AI_SHORTENER_OPENAI_API_KEY=replace-with-your-openai-key

# ---------------------------------------------------------------------------
# DeepSeek (OpenAI-compatible)
# AI_SHORTENER_OPENAI_PROVIDER=deepseek
# AI_SHORTENER_OPENAI_BASE_URL=https://api.deepseek.com/v1/chat/completions
# AI_SHORTENER_OPENAI_MODEL=deepseek-chat
# AI_SHORTENER_OPENAI_API_KEY=replace-with-your-deepseek-key

# ---------------------------------------------------------------------------
# Meta Llama via an OpenAI-compatible host (example: Together AI)
# AI_SHORTENER_OPENAI_PROVIDER=meta-llama
# AI_SHORTENER_OPENAI_BASE_URL=https://api.together.xyz/v1/chat/completions
# AI_SHORTENER_OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# AI_SHORTENER_OPENAI_API_KEY=replace-with-your-host-key

# ---------------------------------------------------------------------------
# Anthropic Claude via an OpenAI-compatible gateway (example: OpenRouter)
# AI_SHORTENER_OPENAI_PROVIDER=anthropic
# AI_SHORTENER_OPENAI_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# AI_SHORTENER_OPENAI_MODEL=anthropic/claude-3.7-sonnet
# AI_SHORTENER_OPENAI_API_KEY=replace-with-your-openrouter-key
